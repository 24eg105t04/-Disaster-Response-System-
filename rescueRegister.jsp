<html>
<head>
<title>Register Rescue Team</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="header">Register Rescue Team</div>

<div class="main">

<form action="saveRescue.jsp" method="post">

<table>

<tr>
<td>Team Name</td>
<td><input type="text" name="team"></td>
</tr>

<tr>
<td>Location</td>
<td><input type="text" name="location"></td>
</tr>

<tr>
<td>Members</td>
<td><input type="text" name="members"></td>
</tr>

<tr>
<td colspan="2">
<button type="submit">Register</button>
</td>
</tr>

</table>

</form>

</div>

</body>
</html>